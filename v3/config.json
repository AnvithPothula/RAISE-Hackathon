{
  "python": {
    "workerModule": "pythos.worker",
    "lowResourceMode": false
  },
  "models": {
    "wakeWord": "Models/wakeword/pythos.onnx",
    "vosk": "Models/vosk/vosk-model-en-us-0.22",
    "piperExecutable": "Models/piper/piper.exe",
    "piperModel": "Models/piper/model.onnx",
    "piperConfig": "Models/piper/model.onnx.json"
  },
  "audio": {
    "chunk": 1280,
    "rate": 16000,
    "channels": 1,
    "wakeWord": "mark",
    "wakeThreshold": 0.25,
    "asrTimeoutSeconds": 10,
    "silenceTimeoutSeconds": 3,
    "ttsLengthScale": 1.15
  },
  "ollama": {
    "baseUrl": "http://127.0.0.1:11434",
    "model": "gemma4:12b",
    "lowResourceModel": "gemma4:e2b",
    "think": "auto"
  },
  "gradium": {
    "baseWsUrl": "wss://api.gradium.ai/api",
    "ttsVoiceId": "YTpq7expH9539ERJ",
    "ttsModel": "default",
    "ttsOutputFormat": "pcm",
    "sttModel": "default",
    "sttInputFormat": "pcm_16000",
    "vadHorizonIndex": 2,
    "vadInactivityThreshold": 0.85,
    "vadMinSilenceSeconds": 1.2
  },
  "pi": {
    "command": "pi",
    "args": [
      "--mode",
      "rpc",
      "--no-session",
      "--model",
      "gemini/gemma-4-26b-a4b-it",
      "--extension",
      ".pi/extensions/pythos-safe-tools.ts",
      "--skill",
      ".pi/skills"
    ],
    "cwd": ".",
    "enabled": false
  },
  "mcp": {
    "enabled": true,
    "servers": [
      {
        "name": "system",
        "enabled": true,
        "transport": "stdio",
        "command": "node",
        "args": [
          "scripts/pythos-mcp-server.mjs"
        ]
      },
      {
        "name": "filesystem",
        "enabled": false,
        "_comment": "Redundant with the local 'system' server (home-sandboxed file tools). Rooted at the repo, so voice queries about ~/Downloads fail. Enable and point at an absolute home path if you want the official npx filesystem server; adds 14 tools and slows first-token latency on the 12B model.",
        "transport": "stdio",
        "command": "npx",
        "args": [
          "-y",
          "@modelcontextprotocol/server-filesystem",
          "."
        ]
      },
      {
        "name": "memory",
        "enabled": false,
        "_comment": "Off by default: the local update_user_memory tool covers the memory demo beat, and this knowledge-graph server nudged Gemma to behave like a coding agent. Enable for a persistent-graph demo.",
        "transport": "stdio",
        "command": "npx",
        "args": [
          "-y",
          "@modelcontextprotocol/server-memory"
        ],
        "env": {
          "MEMORY_FILE_PATH": ".mcp-memory.json"
        }
      }
    ]
  },
  "gui": {
    "visualizer": "compact",
    "showPerformanceStats": true,
    "maxTranscriptItems": 50
  },
  "spotify": {
    "clientId": "3669ef357d6541c0af00e3dd8089823d"
  }
}
