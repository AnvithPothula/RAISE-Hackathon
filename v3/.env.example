# Pythos v3 environment (all values OPTIONAL).
#
# The AI brain runs fully on-device via Ollama + Gemma 4 and needs NO API key.
# Copy this file to `.env`, uncomment what you need, then load it before launch:
#   set -a; source ./.env; set +a && npm run dev
# See API_KEYS_SETUP.txt for details.

# --- Optional: cloud voice (speech-to-text + text-to-speech) ---------------
# Required only for SPOKEN input/output. Typed chat works without it.
# GRADIUM_API_KEY=

# --- Optional: local model overrides ---------------------------------------
# Defaults: gemma4:12b served at http://127.0.0.1:11434
# PYTHOS_OLLAMA_MODEL=gemma4:12b
# PYTHOS_OLLAMA_URL=http://127.0.0.1:11434

# --- Optional: Cursor agent delegation (online coding tasks) ---------------
# PYTHOS_CURSOR_WORKSPACE=/path/to/your/project

# --- Optional: MCP file sandbox root ---------------------------------------
# PYTHOS_MCP_SANDBOX=~

# --- Optional: MCP connector credentials -----------------------------------
# Enable the matching servers in config.json (mcp.servers) after setting these.
# GitHub MCP: create a token at https://github.com/settings/tokens
# GITHUB_PERSONAL_ACCESS_TOKEN=
# Brave Search MCP: get a key at https://brave.com/search/api/
# BRAVE_API_KEY=

# --- Optional: other integrations ------------------------------------------
# PYTHOS_WEB_SEARCH_KEY=
# SPOTIFY_CLIENT_ID=
